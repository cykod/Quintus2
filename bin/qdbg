#!/usr/bin/env bash
set -euo pipefail

# qdbg — Quintus game engine debugger
# Ergonomic wrapper around playwright-cli for debugging running Quintus games.
# Uses a named playwright session "quintus" for persistence.

# ── Prerequisites ────────────────────────────────────────────────────────────

QROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

check_playwright_cli() {
	if ! command -v playwright-cli &>/dev/null; then
		cat >&2 <<'MSG'
Error: playwright-cli is not installed or not in PATH.

The qdbg debugger requires playwright-cli to control the browser.
Install it with:

  npm install -g @anthropic-ai/claude-code

Or if you have Claude Code installed, ensure its bin directory is in your PATH.

playwright-cli is bundled with Claude Code and provides persistent
browser sessions for programmatic page control.
MSG
		exit 1
	fi
}

# ── Usage / Help ─────────────────────────────────────────────────────────────

show_usage() {
	cat <<'USAGE'
qdbg — Quintus game engine debugger

Interactively debug any Quintus game from the terminal. Steps through
frames, inspects the scene tree, injects input, analyzes physics, and
captures screenshots — all via the engine's debug bridge.

PREREQUISITES
  1. playwright-cli must be installed (bundled with Claude Code)
  2. The Quintus dev server must be running: pnpm dev

QUICK START
  pnpm qdbg connect platformer     # Open game in browser, paused
  pnpm qdbg tree                   # See the scene tree
  pnpm qdbg step 60                # Advance 60 frames (1 second)
  pnpm qdbg physics Player         # Inspect player physics state
  pnpm qdbg tap jump 1             # Tap the jump button
  pnpm qdbg screenshot             # Save canvas to PNG
  pnpm qdbg disconnect             # Close browser

COMMANDS
  Connection:
    connect [demo|url]    Open browser with debug bridge (default: platformer)
    disconnect            Close browser session

  Inspection:
    status                Show frame number, elapsed time, paused state
    tree                  Formatted ASCII scene tree
    layout                Spatial overview with physics info
    inspect <name|id>     Detailed node snapshot (JSON)
    query <q>             Find nodes by type/name/tag
    physics <name>        Physics state summary for one node

  Simulation:
    step [N]              Advance N frames (default: 1)
    pause                 Pause game loop
    resume                Resume real-time game loop

  Input:
    actions               List available input actions
    press <action>        Press and hold an action
    release <action>      Release an action
    release-all           Release all held actions
    tap <action> [N]      Press for N frames then release (default: 1)
    click <x> <y>         Click at game-space coordinates
    click-button <text>   Click a UI button by name or text label

  Movement:
    move-to <node> <actions> <x> <y> [--max=N]
                          Hold action(s) until node reaches threshold
                          Use "-" for x or y to ignore that axis
    nearby <name> [rad]   Show nodes within radius (default: 100px)

  Scripting:
    run '<json>'          Execute a DebugAction[] script
    track <name> [N]      Step N frames with tabular tracking (default: 30)
    jump-analysis <name>  Full jump arc analysis with metrics

  Events:
    events [flags]        Drain events since last call
                          --category=  --search=  --limit=  --from=  --to=
    peek [flags]          View events without draining
    clear-events          Clear event log

  Capture:
    screenshot [file]     Save canvas to PNG (default: /tmp/quintus-screenshot.png)

COMMON ISSUES
  "Error: playwright-cli is not installed"
    → Install Claude Code (npm i -g @anthropic-ai/claude-code) which bundles it

  "Error: Debug bridge not found"
    → Run "qdbg connect" first. Every command except connect needs an active session.

  "Error: Dev server failed to start"
    → Run "pnpm dev" manually and check for errors

  "Node not found: Player"
    → Node names are case-sensitive. Run "qdbg tree" to see exact names.

EXAMPLES
  # Debug a custom example
  pnpm qdbg connect my-game

  # Connect to an arbitrary URL
  pnpm qdbg connect http://localhost:8080/game.html

  # Walk player right, jump, and check landing
  pnpm qdbg move-to Player move_right 250 -
  pnpm qdbg tap jump 1
  pnpm qdbg step 60
  pnpm qdbg physics Player

  # Run a scripted sequence
  pnpm qdbg run '[{"press":"move_right","frames":30},{"press":"jump","frames":1},{"wait":20}]'

  # Analyze jump physics
  pnpm qdbg jump-analysis Player

  # Filter events
  pnpm qdbg events --category=physics --search=floor
USAGE
}

# ── Session ──────────────────────────────────────────────────────────────────

SESSION="quintus"
PC="playwright-cli -s=${SESSION}"

# ── Helpers ──────────────────────────────────────────────────────────────────

qeval() {
	# Evaluate a simple JS expression in the browser (no blocks, no IIFE)
	$PC eval "$1"
}

qblock() {
	# Run a JS block (with return statements) in the browser via page.evaluate
	$PC run-code "async page => { return await page.evaluate(() => { $1 }); }"
}

qrun() {
	# Run an async function with full page access (for fs, screenshots, etc.)
	$PC run-code "$1"
}

die() { echo "Error: $*" >&2; exit 1; }

need_bridge() {
	qeval "typeof window.__quintusDebug !== 'undefined' ? 'ok' : 'no'" 2>/dev/null | grep -q "ok" \
		|| die "Debug bridge not found. Run: qdbg connect"
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_connect() {
	local demo="${1:-platformer}"
	local url=""

	# If the argument looks like a URL, use it directly
	if [[ "$demo" == http* ]]; then
		url="$demo"
		# Append ?debug if not already present
		if [[ "$url" != *"debug"* ]]; then
			if [[ "$url" == *"?"* ]]; then url="${url}&debug"; else url="${url}?debug"; fi
		fi
	else
		# Auto-detect Vite dev server port (try 3050-3055)
		local port=""
		for p in 3050 3051 3052 3053 3054 3055; do
			if curl -s "http://localhost:${p}" >/dev/null 2>&1; then
				port=$p
				break
			fi
		done

		echo "Starting dev server if needed..."
		if [ -z "$port" ]; then
			echo "Dev server not running. Starting pnpm dev in background..."
			(cd "$QROOT" && pnpm dev &>/dev/null &)
			for i in $(seq 1 30); do
				for p in 3050 3051 3052 3053 3054 3055; do
					if curl -s "http://localhost:${p}" >/dev/null 2>&1; then port=$p; break 2; fi
				done
				sleep 0.5
			done
			if [ -z "$port" ]; then
				die "Dev server failed to start after 15 seconds"
			fi
			echo "Dev server ready on port ${port}."
		else
			echo "Dev server already running on port ${port}."
		fi
		url="http://localhost:${port}/${demo}/?debug"
	fi

	echo "Opening browser at ${url}..."
	$PC open "$url"

	sleep 0.5
	local check
	check=$(qeval "typeof window.__quintusDebug !== 'undefined' ? 'bridge_ok' : 'no_bridge'" 2>/dev/null || echo "error")
	if echo "$check" | grep -q "bridge_ok"; then
		echo "Debug bridge connected."
		cmd_status
	else
		echo "Warning: Debug bridge not detected. Is ?debug in the URL?"
	fi
}

cmd_disconnect() {
	$PC close
	echo "Browser session closed."
}

cmd_status() {
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		return 'Frame: ' + d.frame + '  Elapsed: ' + d.elapsed.toFixed(3) + 's  Paused: ' + d.paused;
	"
}

cmd_tree() {
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var f = window.__quintusFormatters;
		var snap = d.tree();
		if (!snap) return '(no scene)';
		return f.formatTree(snap);
	"
}

cmd_layout() {
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var snap = d.tree();
		if (!snap) return '(no scene)';
		var nodes = [];
		function walk(n, depth) {
			var p = n.position;
			if (p) {
				var line = '  '.repeat(depth) + n.type;
				if (n.name !== n.type) line += ' \"' + n.name + '\"';
				line += '  pos=(' + p.x.toFixed(1) + ',' + p.y.toFixed(1) + ')';
				if (n.velocity) line += '  vel=(' + n.velocity.x.toFixed(1) + ',' + n.velocity.y.toFixed(1) + ')';
				if (n.isOnFloor) line += '  [floor]';
				if (n.isOnWall) line += '  [wall]';
				if (n.isOnCeiling) line += '  [ceiling]';
				if (n.collisionGroup) line += '  group=' + n.collisionGroup;
				if (n.shape) line += '  shape=' + JSON.stringify(n.shape);
				nodes.push(line);
			}
			(n.children || []).forEach(function(c) { walk(c, depth + 1); });
		}
		walk(snap, 0);
		return nodes.length > 0 ? nodes.join('\n') : '(no spatial nodes)';
	"
}

cmd_inspect() {
	local target="${1:?Usage: qdbg inspect <name|id>}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var snap = d.inspect('${target}');
		if (!snap) snap = d.inspect(Number('${target}'));
		if (!snap) return 'Node not found: ${target}';
		return JSON.stringify(snap, null, 2);
	"
}

cmd_query() {
	local q="${1:?Usage: qdbg query <type|name|tag>}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var results = d.query('${q}');
		if (results.length === 0) return 'No matches for: ${q}';
		return results.map(function(n) {
			var line = n.type;
			if (n.name !== n.type) line += ' \"' + n.name + '\"';
			var p = n.position;
			if (p) line += ' (' + p.x.toFixed(1) + ',' + p.y.toFixed(1) + ')';
			if (n.tags && n.tags.length) line += ' [' + n.tags.join(',') + ']';
			return line;
		}).join('\n');
	"
}

cmd_physics() {
	local target="${1:?Usage: qdbg physics <name>}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var snap = d.inspect('${target}');
		if (!snap) return 'Node not found: ${target}';
		var lines = [];
		lines.push('Node: ' + snap.type + ' \"' + snap.name + '\"');
		if (snap.position) lines.push('Position: (' + snap.position.x.toFixed(2) + ', ' + snap.position.y.toFixed(2) + ')');
		if (snap.globalPosition) lines.push('Global:   (' + snap.globalPosition.x.toFixed(2) + ', ' + snap.globalPosition.y.toFixed(2) + ')');
		if (snap.velocity) lines.push('Velocity: (' + snap.velocity.x.toFixed(2) + ', ' + snap.velocity.y.toFixed(2) + ')');
		if (snap.gravity !== undefined) lines.push('Gravity:  ' + snap.gravity);
		if (snap.isOnFloor !== undefined) lines.push('OnFloor:  ' + snap.isOnFloor);
		if (snap.isOnWall !== undefined) lines.push('OnWall:   ' + snap.isOnWall);
		if (snap.isOnCeiling !== undefined) lines.push('OnCeil:   ' + snap.isOnCeiling);
		if (snap.collisionGroup) lines.push('Group:    ' + snap.collisionGroup);
		if (snap.shape) lines.push('Shape:    ' + JSON.stringify(snap.shape));
		if (snap.tags && snap.tags.length) lines.push('Tags:     ' + snap.tags.join(', '));
		return lines.join('\n');
	"
}

cmd_step() {
	local n="${1:-1}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		d.step(${n});
		return 'Stepped ' + ${n} + ' frame(s). Now at frame ' + d.frame + '  Elapsed: ' + d.elapsed.toFixed(3) + 's';
	"
}

cmd_pause() {
	need_bridge
	qblock "window.__quintusDebug.pause(); return 'Paused at frame ' + window.__quintusDebug.frame;"
}

cmd_resume() {
	need_bridge
	qblock "window.__quintusDebug.resume(); return 'Resumed from frame ' + window.__quintusDebug.frame;"
}

cmd_actions() {
	need_bridge
	qblock "
		var actions = window.__quintusDebug.listActions();
		if (actions.length === 0) return '(no input actions registered)';
		return 'Available actions:\n' + actions.map(function(a) { return '  - ' + a; }).join('\n');
	"
}

cmd_press() {
	local action="${1:?Usage: qdbg press <action>}"
	need_bridge
	qblock "window.__quintusDebug.press('${action}'); return 'Pressed: ${action}';"
}

cmd_release() {
	local action="${1:?Usage: qdbg release <action>}"
	need_bridge
	qblock "window.__quintusDebug.release('${action}'); return 'Released: ${action}';"
}

cmd_release_all() {
	need_bridge
	qblock "window.__quintusDebug.releaseAll(); return 'All actions released.';"
}

cmd_tap() {
	local action="${1:?Usage: qdbg tap <action> [frames]}"
	local frames="${2:-1}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		d.pressAndStep('${action}', ${frames});
		return 'Tapped ${action} for ${frames} frame(s). Now at frame ' + d.frame;
	"
}

cmd_click() {
	local x="${1:?Usage: qdbg click <x> <y>}"
	local y="${2:?Usage: qdbg click <x> <y>}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var hit = d.click(${x}, ${y});
		return hit ? 'Clicked at (${x}, ${y})' : 'No interactive node at (${x}, ${y})';
	"
}

cmd_click_button() {
	local name="${1:?Usage: qdbg click-button <name|text>}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var found = d.clickButton('${name}');
		return found ? 'Clicked button: ${name}' : 'Button not found: ${name}';
	"
}

cmd_run() {
	local json="${1:?Usage: qdbg run '<json>'}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var script = ${json};
		var snaps = d.run(script);
		return 'Ran ' + script.length + ' action(s), ' + snaps.length + ' snapshot(s). Frame: ' + d.frame;
	"
}

cmd_events() {
	need_bridge
	local category="" search="" limit="" from_frame="" to_frame=""
	for arg in "$@"; do
		case "$arg" in
			--category=*) category="${arg#*=}" ;;
			--search=*)   search="${arg#*=}" ;;
			--limit=*)    limit="${arg#*=}" ;;
			--from=*)     from_frame="${arg#*=}" ;;
			--to=*)       to_frame="${arg#*=}" ;;
		esac
	done
	qblock "
		var d = window.__quintusDebug;
		var f = window.__quintusFormatters;
		var filter = {};
		if ('${category}') filter.category = '${category}';
		if ('${search}') filter.search = '${search}';
		if ('${limit}') filter.limit = Number('${limit}');
		if ('${from_frame}') filter.fromFrame = Number('${from_frame}');
		if ('${to_frame}') filter.toFrame = Number('${to_frame}');
		var events = d.events(Object.keys(filter).length > 0 ? filter : undefined);
		return f.formatEvents(events);
	"
}

cmd_peek() {
	need_bridge
	local category="" search="" limit="" from_frame="" to_frame=""
	for arg in "$@"; do
		case "$arg" in
			--category=*) category="${arg#*=}" ;;
			--search=*)   search="${arg#*=}" ;;
			--limit=*)    limit="${arg#*=}" ;;
			--from=*)     from_frame="${arg#*=}" ;;
			--to=*)       to_frame="${arg#*=}" ;;
		esac
	done
	qblock "
		var d = window.__quintusDebug;
		var f = window.__quintusFormatters;
		var filter = {};
		if ('${category}') filter.category = '${category}';
		if ('${search}') filter.search = '${search}';
		if ('${limit}') filter.limit = Number('${limit}');
		if ('${from_frame}') filter.fromFrame = Number('${from_frame}');
		if ('${to_frame}') filter.toFrame = Number('${to_frame}');
		var events = d.peekEvents(Object.keys(filter).length > 0 ? filter : undefined);
		return f.formatEvents(events);
	"
}

cmd_clear_events() {
	need_bridge
	qblock "window.__quintusDebug.clearEvents(); return 'Events cleared.';"
}

cmd_track() {
	local target="${1:?Usage: qdbg track <name> [frames]}"
	local frames="${2:-30}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var rows = [];
		rows.push('Frame  X         Y         Vx        Vy        Floor  Wall   Ceil');
		rows.push('---');
		for (var i = 0; i < ${frames}; i++) {
			d.step(1);
			var s = d.inspect('${target}');
			if (!s) { rows.push('(node lost at step ' + (i+1) + ')'); break; }
			var p = s.position || {x:0,y:0};
			var v = s.velocity || {x:0,y:0};
			rows.push(
				String(d.frame).padStart(5) + '  ' +
				p.x.toFixed(2).padStart(8) + '  ' +
				p.y.toFixed(2).padStart(8) + '  ' +
				v.x.toFixed(2).padStart(8) + '  ' +
				v.y.toFixed(2).padStart(8) + '  ' +
				String(!!s.isOnFloor).padEnd(6) + ' ' +
				String(!!s.isOnWall).padEnd(6) + ' ' +
				String(!!s.isOnCeiling)
			);
		}
		return rows.join('\n');
	"
}

cmd_jump_analysis() {
	local target="${1:?Usage: qdbg jump-analysis <name>}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var before = d.inspect('${target}');
		if (!before) return 'Node not found: ${target}';
		if (!before.isOnFloor) return '${target} is not on the floor. Land first, then retry.';

		var startY = before.position.y;
		var startFrame = d.frame;
		var gravity = before.gravity || 0;

		d.press('jump');
		d.step(1);
		d.release('jump');

		var afterJump = d.inspect('${target}');
		var jumpVy = afterJump ? afterJump.velocity.y : 0;

		var minY = startY;
		var apexFrame = d.frame;
		var landFrame = 0;
		var maxFrames = 300;

		for (var i = 0; i < maxFrames; i++) {
			d.step(1);
			var s = d.inspect('${target}');
			if (!s) break;
			if (s.position.y < minY) {
				minY = s.position.y;
				apexFrame = d.frame;
			}
			if (s.isOnFloor && d.frame > startFrame + 2) {
				landFrame = d.frame;
				break;
			}
		}

		var jumpHeight = startY - minY;
		var totalFrames = landFrame > 0 ? landFrame - startFrame : d.frame - startFrame;
		var apexFrameRel = apexFrame - startFrame;
		var airTimeSec = totalFrames / 60;

		var absJumpForce = Math.abs(jumpVy);
		var theoreticalHeight = gravity > 0 ? (absJumpForce * absJumpForce) / (2 * gravity) : 0;
		var theoreticalAirFrames = gravity > 0 ? (2 * absJumpForce / gravity) * 60 : 0;

		var lines = [];
		lines.push('=== Jump Analysis: ${target} ===');
		lines.push('Start Y:       ' + startY.toFixed(2));
		lines.push('Jump Vy:       ' + jumpVy.toFixed(2));
		lines.push('Gravity:       ' + gravity);
		lines.push('');
		lines.push('--- Measured ---');
		lines.push('Jump Height:   ' + jumpHeight.toFixed(2) + ' px');
		lines.push('Apex Frame:    +' + apexFrameRel + ' frames');
		lines.push('Air Time:      ' + totalFrames + ' frames (' + airTimeSec.toFixed(3) + 's)');
		lines.push('Landed:        ' + (landFrame > 0 ? 'yes (frame ' + landFrame + ')' : 'no (still airborne)'));
		lines.push('');
		lines.push('--- Theoretical ---');
		lines.push('Height:        ' + theoreticalHeight.toFixed(2) + ' px');
		lines.push('Air Frames:    ' + theoreticalAirFrames.toFixed(1));
		if (theoreticalHeight > 0) {
			var pct = ((jumpHeight / theoreticalHeight) * 100).toFixed(1);
			lines.push('Efficiency:    ' + pct + '%');
		}
		return lines.join('\n');
	"
}

cmd_move_to() {
	local target="${1:?Usage: qdbg move-to <node> <actions> <x> <y> [--max=N]}"
	local actions="${2:?Usage: qdbg move-to <node> <actions> <x> <y> [--max=N]}"
	local tx="${3:?Usage: qdbg move-to <node> <actions> <x> <y> [--max=N]}"
	local ty="${4:?Usage: qdbg move-to <node> <actions> <x> <y> [--max=N]}"
	shift 4 || true
	local max_frames=600
	for arg in "$@"; do
		case "$arg" in
			--max=*) max_frames="${arg#*=}" ;;
		esac
	done
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var snap = d.inspect('${target}');
		if (!snap) return 'Node not found: ${target}';
		if (!snap.position) return 'Node has no position: ${target}';

		var actionList = '${actions}'.split(',');
		var tx = '${tx}' === '-' ? null : Number('${tx}');
		var ty = '${ty}' === '-' ? null : Number('${ty}');
		if (tx === null && ty === null) return 'Error: both x and y are \"-\". Specify at least one threshold.';

		var startX = snap.position.x;
		var startY = snap.position.y;
		var startFrame = d.frame;

		for (var i = 0; i < actionList.length; i++) d.press(actionList[i].trim());

		var reached = false;
		var frames = 0;
		for (frames = 0; frames < ${max_frames}; frames++) {
			d.step(1);
			snap = d.inspect('${target}');
			if (!snap) { break; }
			var px = snap.position.x;
			var py = snap.position.y;
			var xOk = tx === null || (tx >= startX ? px >= tx : px <= tx);
			var yOk = ty === null || (ty >= startY ? py >= ty : py <= ty);
			if (xOk && yOk) { reached = true; break; }
		}

		for (var i = 0; i < actionList.length; i++) d.release(actionList[i].trim());

		var endSnap = d.inspect('${target}');
		var ex = endSnap ? endSnap.position.x.toFixed(2) : '?';
		var ey = endSnap ? endSnap.position.y.toFixed(2) : '?';
		var vx = endSnap && endSnap.velocity ? endSnap.velocity.x.toFixed(2) : '?';
		var vy = endSnap && endSnap.velocity ? endSnap.velocity.y.toFixed(2) : '?';
		var floor = endSnap && endSnap.isOnFloor ? ' [floor]' : '';

		if (reached) {
			return 'Reached (' + ex + ', ' + ey + ') in ' + (frames + 1) + ' frames. vel=(' + vx + ', ' + vy + ')' + floor + '  Frame: ' + d.frame;
		} else {
			return 'Stopped at (' + ex + ', ' + ey + ') after ' + frames + ' frames (limit). vel=(' + vx + ', ' + vy + ')' + floor + '  Frame: ' + d.frame;
		}
	"
}

cmd_nearby() {
	local target="${1:?Usage: qdbg nearby <name> [radius]}"
	local radius="${2:-100}"
	need_bridge
	qblock "
		var d = window.__quintusDebug;
		var snap = d.inspect('${target}');
		if (!snap) return 'Node not found: ${target}';
		if (!snap.position) return 'Node has no position: ${target}';
		var px = snap.position.x;
		var py = snap.position.y;
		var r = ${radius};

		var tree = d.tree();
		if (!tree) return '(no scene)';

		var results = [];
		function walk(n) {
			if (!n.position) { (n.children || []).forEach(walk); return; }
			if (n.id === snap.id) { (n.children || []).forEach(walk); return; }
			var dx = n.position.x - px;
			var dy = n.position.y - py;
			var dist = Math.sqrt(dx * dx + dy * dy);
			if (dist <= r) {
				var line = n.type;
				if (n.name !== n.type) line += ' \"' + n.name + '\"';
				line += '  pos=(' + n.position.x.toFixed(1) + ',' + n.position.y.toFixed(1) + ')';
				line += '  dist=' + dist.toFixed(1);
				line += '  delta=(' + dx.toFixed(1) + ',' + dy.toFixed(1) + ')';
				if (n.collisionGroup) line += '  group=' + n.collisionGroup;
				// Find collision shape in children
				var shapes = (n.children || []).filter(function(c) { return c.shapeDesc; });
				if (shapes.length > 0) line += '  shape=' + shapes[0].shapeDesc;
				if (n.bodyType) line += '  [' + n.bodyType + ']';
				if (n.tags && n.tags.length) line += '  tags=' + n.tags.join(',');
				results.push({ dist: dist, line: line });
			}
			(n.children || []).forEach(walk);
		}
		walk(tree);

		if (results.length === 0) return 'No nodes within ' + r + 'px of ${target} at (' + px.toFixed(1) + ',' + py.toFixed(1) + ')';

		results.sort(function(a, b) { return a.dist - b.dist; });
		var header = 'Nearby ${target} (' + px.toFixed(1) + ',' + py.toFixed(1) + ') within ' + r + 'px:';
		return header + '\n' + results.map(function(r) { return '  ' + r.line; }).join('\n');
	"
}

cmd_screenshot() {
	local file="${1:-/tmp/quintus-screenshot.png}"
	need_bridge
	qrun "async page => {
		const dataUrl = await page.evaluate(() => window.__quintusDebug.screenshot());
		const base64 = dataUrl.replace(/^data:image\\/png;base64,/, '');
		const fs = require('fs');
		fs.writeFileSync('${file}', Buffer.from(base64, 'base64'));
		return 'Screenshot saved to ${file}';
	}"
}

# ── Dispatch ─────────────────────────────────────────────────────────────────

cmd="${1:-}"
if [ -z "$cmd" ]; then
	show_usage
	exit 0
fi

shift || true

case "$cmd" in
	help|-h|--help) show_usage ;;
	connect)
		check_playwright_cli
		cmd_connect "$@"
		;;
	disconnect)
		check_playwright_cli
		cmd_disconnect
		;;
	status)       check_playwright_cli; cmd_status ;;
	tree)         check_playwright_cli; cmd_tree ;;
	layout)       check_playwright_cli; cmd_layout ;;
	inspect)      check_playwright_cli; cmd_inspect "$@" ;;
	query)        check_playwright_cli; cmd_query "$@" ;;
	physics)      check_playwright_cli; cmd_physics "$@" ;;
	step)         check_playwright_cli; cmd_step "$@" ;;
	pause)        check_playwright_cli; cmd_pause ;;
	resume)       check_playwright_cli; cmd_resume ;;
	actions)      check_playwright_cli; cmd_actions ;;
	press)        check_playwright_cli; cmd_press "$@" ;;
	release)      check_playwright_cli; cmd_release "$@" ;;
	release-all)  check_playwright_cli; cmd_release_all ;;
	tap)          check_playwright_cli; cmd_tap "$@" ;;
	click)        check_playwright_cli; cmd_click "$@" ;;
	click-button) check_playwright_cli; cmd_click_button "$@" ;;
	run)          check_playwright_cli; cmd_run "$@" ;;
	events)       check_playwright_cli; cmd_events "$@" ;;
	peek)         check_playwright_cli; cmd_peek "$@" ;;
	clear-events) check_playwright_cli; cmd_clear_events ;;
	track)        check_playwright_cli; cmd_track "$@" ;;
	jump-analysis) check_playwright_cli; cmd_jump_analysis "$@" ;;
	move-to)      check_playwright_cli; cmd_move_to "$@" ;;
	nearby)       check_playwright_cli; cmd_nearby "$@" ;;
	screenshot)   check_playwright_cli; cmd_screenshot "$@" ;;
	*)
		echo "Error: Unknown command '$cmd'" >&2
		echo "" >&2
		echo "Run 'qdbg help' for usage." >&2
		exit 1
		;;
esac
