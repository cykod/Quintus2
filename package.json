{
	"name": "quintus-monorepo",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.28.1",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "pnpm --recursive --sort run --if-present build",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"dev": "vite examples",
		"docs": "typedoc",
		"clean": "pnpm --recursive exec rm -rf dist",
		"preinstall": "npx only-allow pnpm"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"tsup": "^8.0.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vitest": "^3.0.0",
		"@vitest/coverage-v8": "^3.0.0",
		"jsdom": "^25.0.0",
		"typedoc": "^0.27.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
